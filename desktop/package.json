{
  "name": "hdm-erp-desktop",
  "version": "1.0.0",
  "description": "HDM ERP Desktop Application",
  "author": "HDM ERP",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"cd ../client && npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "cd ../client && npm run build && rd /s /q ..\\desktop\\build 2>nul & xcopy /E /I dist ..\\desktop\\build",
    "pack:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "electron-updater": "^6.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "wait-on": "^7.2.0"
  }
}
